<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MentraOS Example App</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>MentraOS Example App</h1>
        </header>
        <div class="instructions">
            <% if (userId) { %>
                <p>Logged in as: <span class="user-id"><%= userId %></span></p>
            <% } else { %>
                <p>Not logged in</p>
            <% } %>
        </div>
        <div class="scan-history">
            <h2>Scan History</h2>
            <% if (scans && scans.length > 0) { %>
                <table>
                    <thead>
                        <tr>
                            <th>Barcode Text</th>
                            <th>Format</th>
                            <th>Timestamp</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% scans.forEach(function(scan) { %>
                            <tr>
                                <td><%= scan.text %></td>
                                <td><%= scan.format %></td>
                                <td><%= new Date(scan.timestamp).toLocaleString() %></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } else { %>
                <p>No scans available.</p>
            <% } %>
        </div>
    </div>
</body>
</html>