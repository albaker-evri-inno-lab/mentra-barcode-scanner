<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Barcode Scanner</title>
  <style>
    body { font-family: sans-serif; max-width: 480px; margin: 40px auto; padding: 0 16px; background: #f5f5f5; }
    h1 { font-size: 1.4rem; margin-bottom: 4px; }
    .status { font-size: 0.85rem; color: #666; margin-bottom: 24px; }
    button {
      width: 100%; padding: 16px; font-size: 1.1rem; font-weight: bold;
      background: #1a1a1a; color: white; border: none; border-radius: 10px;
      cursor: pointer; margin-bottom: 24px;
    }
    button:disabled { background: #999; cursor: not-allowed; }
    #status-msg { text-align: center; font-size: 0.9rem; color: #444; margin-bottom: 16px; min-height: 20px; }
    h2 { font-size: 1rem; color: #333; margin-bottom: 8px; }
    .scan-list { list-style: none; padding: 0; margin: 0; }
    .scan-item {
      background: white; border-radius: 8px; padding: 12px 16px;
      margin-bottom: 8px; border-left: 4px solid #1a1a1a;
    }
    .scan-format { font-size: 0.75rem; color: #888; font-weight: bold; text-transform: uppercase; }
    .scan-text { font-size: 1rem; word-break: break-all; margin-top: 2px; }
    .scan-time { font-size: 0.75rem; color: #aaa; margin-top: 4px; }
    .empty { color: #aaa; font-size: 0.9rem; text-align: center; padding: 24px 0; }
  </style>
</head>
<body>
  <h1>📷 Barcode Scanner</h1>
  <p class="status">
    <% if (userId) { %>Connected as <%= userId %><% } else { %>Not authenticated<% } %>
  </p>

  <% if (userId) { %>
    <button id="scan-btn" onclick="triggerScan()">Scan Barcode</button>
    <div id="status-msg"></div>

    <h2>Scan History</h2>
    <ul class="scan-list" id="scan-list">
      <% if (scans.length === 0) { %>
        <li class="empty">No scans yet — point the glasses camera at a barcode and tap Scan</li>
      <% } else { %>
        <% scans.slice().reverse().forEach(scan => { %>
          <li class="scan-item">
            <div class="scan-format"><%= scan.format %></div>
            <div class="scan-text"><%= scan.text %></div>
            <div class="scan-time"><%= new Date(scan.timestamp).toLocaleTimeString() %></div>
          </li>
        <% }) %>
      <% } %>
    </ul>
  <% } else { %>
    <p class="empty">Open this page from the MentraOS app to authenticate.</p>
  <% } %>

  <script>
    async function triggerScan() {
      const btn = document.getElementById('scan-btn');
      const msg = document.getElementById('status-msg');
      btn.disabled = true;
      btn.textContent = 'Scanning...';
      msg.textContent = 'Capturing image from glasses camera...';
      try {
        const res = await fetch('/api/scan', { method: 'POST' });
        const data = await res.json();
        if (!res.ok) {
          msg.textContent = '❌ ' + data.error;
        } else {
          msg.textContent = '✅ ' + (data.result || 'Done');
          refreshList(data.scans);
        }
      } catch (e) {
        msg.textContent = '❌ Request failed';
      } finally {
        btn.disabled = false;
        btn.textContent = 'Scan Barcode';
      }
    }

    function refreshList(scans) {
      const list = document.getElementById('scan-list');
      if (!scans || scans.length === 0) return;
      list.innerHTML = scans.slice().reverse().map(s => `
        <li class="scan-item">
          <div class="scan-format">${s.format}</div>
          <div class="scan-text">${s.text}</div>
          <div class="scan-time">${new Date(s.timestamp).toLocaleTimeString()}</div>
        </li>`).join('');
    }
  </script>
</body>
</html>