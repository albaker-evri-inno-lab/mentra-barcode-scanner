{
  "description": "A extended example app that shows how to use MentraOS.",
  "permissions": [
    {
      "type": "MICROPHONE",
      "description": "To show transcriptions"
    },
    {
      "type": "CAMERA",
      "description": "To capture images for barcode scanning"
    }
  ],
  "settings": [
    {
      "type": "toggle",
      "key": "show_live_transcription",
      "label": "Show live transcription",
      "defaultValue": true
    },
    {
      "type": "toggle",
      "key": "enable_barcode_scanning",
      "label": "Enable barcode scanning",
      "defaultValue": true
    }
  ],
  "tools": [
    {
      "id": "my_tool_name",
      "description": "This is a tool that does something.",
      "activationPhrases": [
        "my tool name",
        "use my tool"
      ],
      "parameters": { }
    },
    {
      "id": "scan_barcode",
      "description": "Scan a barcode using the glasses camera.",
      "activationPhrases": [
        "scan barcode",
        "read barcode"
      ],
      "parameters": { }
    }
  ]
}